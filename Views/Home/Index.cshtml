        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100 sw-card-lift">
                    <i class="bi bi-lightning-charge-fill fs-1 text-primary mb-3 d-block"></i>
                    <h6 class="fw-bold">Easy Pricing</h6>
                    <p class="text-muted small mb-0">Simple per-kg pricing with no hidden fees</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100 sw-card-lift">
                    <i class="bi bi-geo-alt-fill fs-1 text-primary mb-3 d-block"></i>
                    <h6 class="fw-bold">Pickup & Delivery</h6>
                    <p class="text-muted small mb-0">Door-to-door service across Metro Manila</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100 sw-card-lift">
                    <i class="bi bi-droplet-fill fs-1 text-primary mb-3 d-block"></i>
                    <h6 class="fw-bold">Eco-Friendly</h6>
                    <p class="text-muted small mb-0">We use sustainable, eco-friendly detergents</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100 sw-card-lift">
                    <i class="bi bi-shield-check fs-1 text-primary mb-3 d-block"></i>
                    <h6 class="fw-bold">100% Guaranteed</h6>
                    <p class="text-muted small mb-0">Your satisfaction is our top priority</p>
                </div>
            </div>
