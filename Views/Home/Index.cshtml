                    <span style="color:var(--sw-gray-400); font-size: 0.9rem;">Makati City Customer</span>
                </div>
                <div class="d-flex flex-wrap gap-4 align-items-center mt-4">
                    <i class="bi bi-flower1 fs-3" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <i class="bi bi-balloon fs-3" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <i class="bi bi-badge-ad fs-3" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <i class="bi bi-bookmark-star fs-3" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <i class="bi bi-brightness-high fs-3" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <i class="bi bi-briefcase fs-3 d-none d-md-block" style="color:var(--sw-primary-light); filter: brightness(0.6);"></i>
                    <a href="/Auth/Register" class="text-primary fw-semibold ms-auto text-decoration-none d-flex align-items-center gap-2">Meet all customers <i class="bi bi-arrow-right fw-bold"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

