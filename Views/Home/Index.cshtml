@{
    ViewData["Title"] = "Fresh Laundry Delivered to Your Door";
    var services = ViewBag.Services as List<SmartWash.Models.Service> ?? new List<SmartWash.Models.Service>();
    var announcements = ViewBag.Announcements as List<SmartWash.Models.Announcement> ?? new List<SmartWash.Models.Announcement>();
}

@foreach (var ann in announcements)
{
    <div class="alert alert-primary alert-dismissible fade show mb-0 sw-announcement-banner rounded-0 text-center" role="alert" style="border:none;">
        <div class="container d-flex align-items-center justify-content-center">
            <i class="bi bi-megaphone-fill me-2"></i>
            <strong class="me-2">@ann.Title</strong> @ann.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<section class="sw-hero" id="home">
    <div class="container sw-hero-content">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 text-center text-lg-start pe-lg-5">
                <h1 class="sw-hero-title mb-3">
                    Fresh Clothes, <br />
                    <span style="color: var(--sw-primary);">Zero Effort.</span>
                </h1>
                <p class="sw-hero-subtitle mb-4 mx-auto mx-lg-0">
                    Just weigh, book, and relax. We pick up your dirty laundry and deliver it back fresh, clean, and perfectly folded — right to your doorstep.
                </p>
                <a href="/Auth/Register" class="sw-btn sw-btn-primary px-4 py-2" style="font-size: 1rem;">
                    Register Now
                </a>
            </div>
            <div class="col-lg-5 text-center mt-5 mt-lg-0">
                <img src="https://images.unsplash.com/photo-1545173168-9f1947eebb7f?w=600&h=500&fit=crop" alt="Hero illustration" class="img-fluid bg-transparent" style="max-height:400px; border-radius: 8px;" />
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background:var(--sw-white);">
    <div class="container text-center py-4">
        <h2 class="fw-bold fs-3 mb-2" style="color:var(--sw-gray-600);">Our Clients</h2>
        <p class="mb-4" style="color:var(--sw-gray-400);">We have been working with some Fortune 500+ clients</p>
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-4 my-5 px-lg-4">
            <i class="bi bi-asterisk fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-bezier fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-box-fill fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-camera-reels-fill fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-command fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-infinity fs-1" style="color:var(--sw-gray-200);"></i>
            <i class="bi bi-hexagon-fill fs-1" style="color:var(--sw-gray-200);"></i>
        </div>
    </div>
</section>

<section id="services" class="py-5" style="background:var(--sw-white);">
    <div class="container text-center px-lg-5">
        <h2 class="fw-bold fs-2 mb-2" style="color:var(--sw-gray-600); max-width: 500px; margin: 0 auto;">Professional Laundry Care</h2>
        <p class="mb-5" style="color:var(--sw-gray-400);">Choose from our range of premium laundry services</p>
        <div class="row g-5">
            @foreach (var svc in services)
            {
                <div class="col-md-4">
                    <div class="px-3">
                        <div class="mb-3 d-inline-block position-relative">
                            <div class="fs-1 d-flex align-items-center justify-content-center position-relative" style="width: 60px; height: 60px; z-index: 2; margin: 0 auto; color:var(--sw-success);">
                                @Html.Raw(svc.Icon)
                            </div>
                            <div class="position-absolute" style="width:45px; height:45px; background:var(--sw-success-light); top:5px; right:-15px; border-top-left-radius: 15px; border-bottom-right-radius: 15px; border-top-right-radius: 5px; border-bottom-left-radius: 5px; z-index:1;"></div>
                        </div>
                        <h4 class="fw-bold fs-4 mb-2" style="color:var(--sw-gray-600);">@svc.Name</h4>
                        <p style="color:var(--sw-gray-400); font-size:0.9rem;">@svc.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5" style="background:var(--sw-white);">
    <div class="container py-lg-4">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5 text-center px-4">
                <img src="https://images.unsplash.com/photo-1544441893-675973e31985?w=500&h=500&fit=crop" alt="Illustration" class="img-fluid" style="border-radius:12px; box-shadow:var(--sw-shadow-lg);" />
            </div>
            <div class="col-lg-7 ps-lg-5">
                <h2 class="fw-bold mb-3 pe-lg-5" style="color:var(--sw-gray-600); font-size: 2.2rem; line-height: 1.2;">
                    Simple as 1-2-3-4:<br/>How SmartWash Works
                </h2>
                <div style="color:var(--sw-gray-400); font-size:0.95rem; line-height:1.6;" class="mb-4 pe-lg-5">
                    <p class="mb-3">SmartWash simplifies laundry with a clear, fast, and transparent process that fits your busy life style. Stop worrying about doing your laundry and let the experts handle it.</p>
                    <p class="mb-2"><strong>1. Weigh:</strong> Estimate your laundry weight using our guide.</p>
                    <p class="mb-2"><strong>2. Pick Service:</strong> Choose the perfect plan for your fabric.</p>
                    <p class="mb-2"><strong>3. Book Slot:</strong> Pick your preferred date and time.</p>
                    <p class="mb-0"><strong>4. We Deliver:</strong> We pick up, wash, and deliver back to you.</p>
                </div>
                <a href="/Order/Place" class="sw-btn sw-btn-primary px-4 py-2 mt-2">Book Now</a>
            </div>
        </div>
    </div>
</section>

