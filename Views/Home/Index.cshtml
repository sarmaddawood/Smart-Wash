                        <i class="bi bi-geo-alt fs-1" style="color:var(--sw-primary);"></i>
                        <div>
                            <h3 class="fw-bold mb-0" style="color:var(--sw-gray-600); font-size:1.7rem;">12+</h3>
                            <span style="color:var(--sw-gray-400); font-size:0.85rem;">Areas Served</span>
                        </div>
                    </div>
                    <div class="col-6 d-flex align-items-center gap-3">
                        <i class="bi bi-rocket fs-1" style="color:var(--sw-primary);"></i>
