@{
    ViewData["Title"] = "Fresh Laundry Delivered to Your Door";
    var services = ViewBag.Services as List<SmartWash.Models.Service> ?? new List<SmartWash.Models.Service>();
    var announcements = ViewBag.Announcements as List<SmartWash.Models.Announcement> ?? new List<SmartWash.Models.Announcement>();
}

@foreach (var ann in announcements)
{
    <div class="alert alert-primary alert-dismissible fade show mb-0 sw-announcement-banner" role="alert">
        <div class="container d-flex align-items-center">
            <i class="bi bi-megaphone-fill me-2"></i>
            <strong class="me-2">@ann.Title</strong> @ann.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<section class="sw-hero">
    <div class="container sw-hero-content">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="sw-hero-pill mb-3">
                    <i class="bi bi-stars"></i> Philippines' #1 Laundry Service
                </div>
                <h1 class="sw-hero-title mb-3">
                    Fresh Clothes,<br />
                    <span style="color: #60a5fa;">Zero Effort.</span>
                </h1>
                <p class="sw-hero-subtitle mb-4">
                    Just weigh, book, and relax. We pick up your dirty laundry and deliver it back fresh, clean, and perfectly folded — right to your doorstep.
                </p>
                <div class="d-flex gap-3 flex-wrap mb-4">
                    <a href="/Order/Place" class="sw-btn sw-btn-primary sw-btn-pulse px-4">
                        <i class="bi bi-basket-fill"></i> Book Now
                    </a>
                    <a href="#services" class="sw-btn sw-btn-outline px-4">
                        <i class="bi bi-tag"></i> See Pricing
                    </a>
                </div>
                <div class="sw-hero-stats">
                    <div class="sw-hero-stat">
                        <span class="sw-hero-stat-value">2,400+</span>
                        <span class="sw-hero-stat-label">Orders Done</span>
                    </div>
                    <div class="sw-hero-stat">
                        <span class="sw-hero-stat-value">⭐ 4.9</span>
                        <span class="sw-hero-stat-label">Rating</span>
                    </div>
                    <div class="sw-hero-stat">
                        <span class="sw-hero-stat-value">24hr</span>
                        <span class="sw-hero-stat-label">Turnaround</span>
                    </div>
                    <div class="sw-hero-stat">
                        <span class="sw-hero-stat-value">100%</span>
                        <span class="sw-hero-stat-label">Satisfaction</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1545173168-9f1947eebb7f?w=600&h=500&fit=crop" alt="Fresh clean laundry" class="sw-hero-img" />
            </div>
        </div>
    </div>
</section>

<section class="sw-stats-bar">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-lg-3">
                <div class="sw-stat-item">
                    <div class="sw-stat-icon">📦</div>
                    <span class="sw-stat-value">2,400+</span>
                    <span class="sw-stat-label">Orders Completed</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-stat-item">
                    <div class="sw-stat-icon">⭐</div>
                    <span class="sw-stat-value">4.9 Rating</span>
                    <span class="sw-stat-label">From Happy Customers</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-stat-item">
                    <div class="sw-stat-icon">📍</div>
                    <span class="sw-stat-value">Metro Manila</span>
                    <span class="sw-stat-label">& Nearby Provinces</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-stat-item">
                    <div class="sw-stat-icon">🚀</div>
                    <span class="sw-stat-value">Same-Day</span>
                    <span class="sw-stat-label">Available for Express</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="services" class="py-5 sw-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="sw-section-badge"><i class="bi bi-stars"></i> Our Services</span>
            <h2 class="sw-section-title text-center">Professional Laundry Care</h2>
            <p class="text-muted mx-auto mt-3" style="max-width:500px;">Choose from our range of premium laundry services — expert care for every fabric type.</p>
        </div>
        <div class="row g-4">
            @foreach (var svc in services)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="sw-service-card h-100">
                        <span class="sw-verified-badge"><i class="bi bi-check-circle-fill me-1"></i>Verified</span>
                        <div class="p-4 text-center">
                            <div class="sw-service-icon-wrap">@svc.Icon</div>
                            <h5 class="fw-bold mb-2">@svc.Name</h5>
                            <p class="text-muted small mb-3" style="min-height:40px;">@svc.Description</p>
                            <div class="d-flex justify-content-center gap-2 mb-2">
                                <span class="sw-price-tag">₱@svc.PricePerKg/kg</span>
                                <span class="sw-max-tag">Up to @svc.MaxKg kg</span>
                            </div>
                            <div class="sw-rating mb-3">⭐⭐⭐⭐⭐ <span class="text-muted ms-1">4.9</span></div>
                            <a href="/Order/Place" class="sw-btn sw-btn-primary w-100">
                                <i class="bi bi-cart-plus"></i> Book Now
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 sw-section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <span class="sw-section-badge"><i class="bi bi-box"></i> Weight Guide</span>
            <h2 class="sw-section-title text-center">Know Your Laundry Weight</h2>
        </div>
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-4 col-lg-2">
                <div class="sw-weight-card text-center p-3">
                    <span class="fs-1">👕</span>
                    <p class="fw-semibold mb-0 small mt-1">T-shirt</p>
                    <span class="text-primary fw-bold">~0.2kg</span>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="sw-weight-card text-center p-3">
                    <span class="fs-1">👖</span>
                    <p class="fw-semibold mb-0 small mt-1">Jeans</p>
                    <span class="text-primary fw-bold">~0.7kg</span>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="sw-weight-card text-center p-3">
                    <span class="fs-1">🧥</span>
                    <p class="fw-semibold mb-0 small mt-1">Jacket</p>
                    <span class="text-primary fw-bold">~1kg</span>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="sw-weight-card text-center p-3">
                    <span class="fs-1">🛏️</span>
                    <p class="fw-semibold mb-0 small mt-1">Bed Sheet</p>
                    <span class="text-primary fw-bold">~0.5kg</span>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="sw-weight-card text-center p-3">
                    <span class="fs-1">🧦</span>
                    <p class="fw-semibold mb-0 small mt-1">Socks (pair)</p>
                    <span class="text-primary fw-bold">~0.1kg</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="how-it-works" class="py-5 sw-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="sw-section-badge"><i class="bi bi-arrow-repeat"></i> How It Works</span>
            <h2 class="sw-section-title text-center">Simple as 1-2-3-4</h2>
        </div>
        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100">
                    <div class="sw-step-num">1</div>
                    <i class="bi bi-speedometer fs-1 text-primary mb-2 d-block"></i>
                    <h6 class="fw-bold">Weigh</h6>
                    <p class="text-muted small mb-0">Estimate your laundry weight using our guide</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100">
                    <div class="sw-step-num">2</div>
                    <i class="bi bi-hand-index fs-1 text-primary mb-2 d-block"></i>
                    <h6 class="fw-bold">Pick Service</h6>
                    <p class="text-muted small mb-0">Choose the perfect plan for your fabric</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100">
                    <div class="sw-step-num">3</div>
                    <i class="bi bi-calendar-check fs-1 text-primary mb-2 d-block"></i>
                    <h6 class="fw-bold">Book Slot</h6>
                    <p class="text-muted small mb-0">Pick your preferred date and time</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="sw-step-card p-4 text-center h-100">
                    <div class="sw-step-num">4</div>
                    <i class="bi bi-truck fs-1 text-primary mb-2 d-block"></i>
                    <h6 class="fw-bold">We Deliver</h6>
                    <p class="text-muted small mb-0">We pick up, wash, and deliver back to you</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 sw-section-alt">
    <div class="container">
        <div class="text-center mb-5">
            <span class="sw-section-badge"><i class="bi bi-chat-quote"></i> Reviews</span>
            <h2 class="sw-section-title text-center">What Our Customers Say</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="sw-review-card p-4 h-100">
                    <div class="sw-rating mb-2">⭐⭐⭐⭐⭐</div>
