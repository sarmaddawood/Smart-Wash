@{
    Layout = "_Layout";
    ViewData["Title"] = "Rider Dashboard";
    var pendingOrders = ViewBag.PendingOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var readyOrders = ViewBag.ReadyOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var activeJobs = ViewBag.MyActiveOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var serviceDict = ViewBag.ServiceDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    var profileDict = ViewBag.ProfileDict as Dictionary<string, SmartWash.Models.Profile> ?? new Dictionary<string, SmartWash.Models.Profile>();
    var riderId = ViewBag.RiderId as string;
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Rider Dashboard</h1>
        <div class="text-muted fs-12">Welcome, @ViewBag.UserName</div>
    </div>

    <div class="card animate-stagger delay-1 p-3 mb-4">
        <ul class="nav nav-tabs mb-3" id="riderTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fs-12 fw-bold text-uppercase" id="pickups-tab" data-bs-toggle="tab" data-bs-target="#pickups" type="button" role="tab">Available Pickups</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fs-12 fw-bold text-uppercase" id="deliveries-tab" data-bs-toggle="tab" data-bs-target="#deliveries" type="button" role="tab">Available Deliveries</button>
            </li>
        </ul>
        <div class="tab-content" id="riderTabsContent">
            <div class="tab-pane fade show active" id="pickups" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-sm table-hover text-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Pickup Address</th>
                                <th class="fs-12 text-muted text-uppercase">Date</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in pendingOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td class="text-truncate" style="max-width: 200px;">@order.PickupAddress</td>
                                    <td>@order.PickupDate?.ToString("MMM dd, yyyy")</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Rider", new { id = order.Id })" class="btn btn-primary btn-sm">View & Accept</a>
                                    </td>
                                </tr>
                            }
                            @if (!pendingOrders.Any())
                            {
                                <tr><td colspan="6" class="text-center py-3 text-muted">No available pickups.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane fade" id="deliveries" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-sm table-hover text-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Delivery Address</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in readyOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td class="text-truncate" style="max-width: 200px;">@order.DeliveryAddress</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Rider", new { id = order.Id })" class="btn btn-primary btn-sm">View & Accept</a>
                                    </td>
                                </tr>
                            }
                            @if (!readyOrders.Any())
                            {
                                <tr><td colspan="5" class="text-center py-3 text-muted">No available deliveries.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <h2 class="mb-3">My Active Jobs</h2>
    <div class="card animate-stagger delay-2 p-3">
        <div class="table-responsive">
            <table class="table table-sm table-hover text-nowrap mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="fs-12 text-muted text-uppercase">Order ID</th>
                        <th class="fs-12 text-muted text-uppercase">Customer</th>
                        <th class="fs-12 text-muted text-uppercase">Type</th>
                        <th class="fs-12 text-muted text-uppercase">Status</th>
                        <th class="fs-12 text-muted text-uppercase">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in activeJobs)
                    {
                        var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                        var isPickup = order.PickupRiderId == riderId;
                        <tr>
                            <td>@order.Id.Substring(0, 8)...</td>
                            <td>@(customer?.FullName ?? "Unknown")</td>
                            <td>
                                <span class="badge @(isPickup ? "bg-info" : "bg-warning") text-dark rounded-pill fs-12">
                                    @(isPickup ? "Pickup" : "Delivery")
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-secondary rounded-pill fs-12">@order.Status</span>
                            </td>
                            <td>
                                <a href="@Url.Action("OrderDetail", "Rider", new { id = order.Id })" class="btn btn-outline-primary btn-sm">Manage</a>
                            </td>
                        </tr>
                    }
                    @if (!activeJobs.Any())
                    {
                        <tr><td colspan="5" class="text-center py-3 text-muted">You have no active jobs.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
