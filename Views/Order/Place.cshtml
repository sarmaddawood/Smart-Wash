@{
    ViewData["Title"] = "Place Order";
    var services = ViewBag.Services as List<SmartWash.Models.Service> ?? new List<SmartWash.Models.Service>();
    var detergents = ViewBag.Detergents as List<SmartWash.Models.Detergent> ?? new List<SmartWash.Models.Detergent>();
    var conditioners = ViewBag.Conditioners as List<SmartWash.Models.Conditioner> ?? new List<SmartWash.Models.Conditioner>();
    var userName = ViewBag.UserName as string ?? "";
    var userEmail = ViewBag.UserEmail as string ?? "";
    var userPhone = ViewBag.UserPhone as string ?? "";
}

<div class="sw-page-header">
    <div class="container">
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-basket-fill me-2"></i>Place New Order</h2>
        <p class="text-muted mb-0">Follow the steps below to place your laundry order</p>
    </div>
</div>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="sw-wizard mb-4">
                <div class="sw-wizard-step active" data-step="1"><span class="sw-step-badge">1</span>Service</div>
                <div class="sw-wizard-step" data-step="2"><span class="sw-step-badge">2</span>Location</div>
                <div class="sw-wizard-step" data-step="3"><span class="sw-step-badge">3</span>Schedule</div>
            </div>

            <form method="post" action="/Order/Place" id="orderForm">
                <div class="sw-step-content" id="step1">
                    <div class="sw-card animate-stagger delay-1 mb-4">
                        <div class="p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-stars text-primary me-2"></i>Select Service</h5>
                            <div class="row g-3 mb-3">
                                @foreach (var svc in services)
                                {
                                    <div class="col-md-6">
                                        <div class="sw-service-select-card p-3" data-service-id="@svc.Id" data-price="@svc.PricePerKg" data-name="@svc.Name" onclick="selectService(this)">
                                            <div class="d-flex align-items-center">
                                                <div class="sw-service-icon-wrap me-3" style="width:48px;height:48px;margin:0;font-size:1.3rem;">@svc.Icon</div>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@svc.Name</h6>
                                                    <p class="text-muted small mb-0">@svc.Description</p>
                                                    <span class="text-primary fw-bold small">₱@svc.PricePerKg/kg</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="hidden" name="serviceId" id="serviceId" required />
                            <div id="serviceError" class="text-danger small d-none"><i class="bi bi-exclamation-circle me-1"></i>Please select a service</div>

                            <h5 class="fw-bold mb-3 mt-4"><i class="bi bi-droplet-fill text-primary me-2"></i>Select Detergent</h5>
                            <div class="row g-3 mb-3">
                                @foreach (var det in detergents)
                                {
                                    <div class="col-md-4 col-6">
                                        <div class="sw-service-select-card p-3 text-center" data-detergent-id="@det.Id" data-detergent-name="@det.Name" onclick="selectDetergent(this)">
                                            <div class="sw-service-icon-wrap mx-auto mb-2" style="width:40px;height:40px;margin:0;font-size:1rem;">🧴</div>
                                            <h6 class="fw-bold mb-0 small">@det.Name</h6>
                                            @if (!string.IsNullOrEmpty(det.Brand))
                                            {
                                                <span class="text-muted" style="font-size:0.72rem;">@det.Brand</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="hidden" name="detergentId" id="detergentId" required />
                            <div id="detergentError" class="text-danger small d-none"><i class="bi bi-exclamation-circle me-1"></i>Please select a detergent</div>

                            <h5 class="fw-bold mb-3 mt-4"><i class="bi bi-flower1 text-primary me-2"></i>Select Conditioner</h5>
                            <div class="row g-3 mb-3">
                                @foreach (var con in conditioners)
                                {
                                    <div class="col-md-4 col-6">
                                        <div class="sw-service-select-card p-3 text-center" data-conditioner-id="@con.Id" data-conditioner-name="@con.Name" onclick="selectConditioner(this)">
                                            <div class="sw-service-icon-wrap mx-auto mb-2" style="width:40px;height:40px;border-color:var(--sw-secondary);background:var(--sw-secondary-light);color:var(--sw-secondary);margin:0;font-size:1rem;">🌸</div>
                                            <h6 class="fw-bold mb-0 small">@con.Name</h6>
                                            @if (!string.IsNullOrEmpty(con.Brand))
                                            {
                                                <span class="text-muted" style="font-size:0.72rem;">@con.Brand</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="hidden" name="conditionerId" id="conditionerId" required />
                            <div id="conditionerError" class="text-danger small d-none"><i class="bi bi-exclamation-circle me-1"></i>Please select a conditioner</div>

                            <div class="mb-3 mt-3">
                                <label class="form-label fw-semibold small">Special Instructions (optional)</label>
                                <textarea name="specialInstructions" class="form-control sw-input sw-textarea-auto" rows="1" maxlength="300" placeholder="e.g., Pakihiwalay po ang puti at de-kulay, use fabric softener for bedsheets..."></textarea>
                            </div>
                            <button type="button" class="sw-btn sw-btn-primary" onclick="goToStep(2)">
                                Continue <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="sw-step-content d-none" id="step2">
                    <div class="sw-card animate-stagger delay-1 mb-4">
                        <div class="p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt-fill text-primary me-2"></i>Pickup & Delivery Location</h5>
                            <div id="orderMap" style="height:350px;border-radius:12px;" class="mb-3"></div>
                            <button type="button" class="sw-btn sw-btn-outline mb-3" style="color:var(--sw-primary);border-color:var(--sw-primary);min-height:36px;padding:6px 16px;font-size:0.85rem;" onclick="useMyLocation()">
                                <i class="bi bi-crosshair"></i> Use My Location
                            </button>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold small"><i class="bi bi-geo-alt text-danger me-1"></i>Pickup Address</label>
                                    <textarea name="pickupAddress" id="pickupAddress" class="form-control sw-input sw-textarea-auto" rows="1" placeholder="📍 Pickup address here..." required></textarea>
                                    <input type="hidden" name="pickupLat" id="pickupLat" />
                                    <input type="hidden" name="pickupLng" id="pickupLng" />
                                </div>
                                <div class="col-12 text-end">
                                    <div class="form-check d-inline-block">
                                        <input class="form-check-input" type="checkbox" id="sameAsPickup" checked onchange="toggleSameAddress(this)">
                                        <label class="form-check-label small fw-semibold" for="sameAsPickup">Deliver to same address</label>
                                    </div>
                                </div>
                                <div class="col-12 d-none" id="deliveryContainer">
                                    <label class="form-label fw-semibold small"><i class="bi bi-house text-success me-1"></i>Delivery Address</label>
                                    <textarea name="deliveryAddress" id="deliveryAddress" class="form-control sw-input sw-textarea-auto" rows="1" placeholder="🏠 Delivery address here..." required></textarea>
                                    <input type="hidden" name="deliveryLat" id="deliveryLat" />
                                    <input type="hidden" name="deliveryLng" id="deliveryLng" />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <button type="button" class="sw-btn sw-btn-outline" style="color:var(--sw-gray-500);border-color:var(--sw-gray-300);" onclick="goToStep(1)">
                                    <i class="bi bi-arrow-left"></i> Back
                                </button>
                                <button type="button" class="sw-btn sw-btn-primary" onclick="goToStep(3)">
                                    Continue <i class="bi bi-arrow-right ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="sw-step-content d-none" id="step3">
                    <div class="sw-card animate-stagger delay-1 mb-4">
                        <div class="p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event text-primary me-2"></i>Schedule Pickup</h5>
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Preferred Pickup Date & Time</label>
                                <input type="datetime-local" name="pickupDate" id="pickupDate" class="form-control sw-input" required />
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="sw-btn sw-btn-outline" style="color:var(--sw-gray-500);border-color:var(--sw-gray-300);" onclick="goToStep(2)">
                                    <i class="bi bi-arrow-left"></i> Back
                                </button>
                                <button type="submit" class="sw-btn sw-btn-primary sw-btn-pulse flex-fill">
                                    <i class="bi bi-check-circle"></i> Place Order
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="sw-card sw-summary-card animate-stagger delay-2 sticky-top" style="top:80px;">
                <div class="p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-receipt text-primary me-2"></i>Order Summary</h6>
                    <div class="d-flex justify-content-between small mb-2">
                        <span class="text-muted">Service:</span>
                        <span class="fw-semibold" id="summaryService">—</span>
                    </div>
                    <div class="d-flex justify-content-between small mb-2">
                        <span class="text-muted">Detergent:</span>
                        <span class="fw-semibold" id="summaryDetergent">—</span>
                    </div>
                    <div class="d-flex justify-content-between small mb-2">
                        <span class="text-muted">Conditioner:</span>
                        <span class="fw-semibold" id="summaryConditioner">—</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between small mb-2">
                        <span class="text-muted">Weight:</span>
                        <span class="fw-semibold text-muted">Measured at warehouse</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="fw-bold">Total:</span>
                        <span class="fw-bold text-muted">Calculated after weighing</span>
                    </div>
                    <hr />
                    <div class="small mb-1">
                        <i class="bi bi-geo-alt text-danger me-1"></i>
                        <span class="text-muted" id="summaryPickup">Pickup: Not set</span>
                    </div>
                    <div class="small">
                        <i class="bi bi-house text-success me-1"></i>
                        <span class="text-muted" id="summaryDelivery">Delivery: Not set</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var selectedName = '';
    var selectedDetergentName = '';
    var selectedConditionerName = '';
    var map, pickupMarker, deliveryMarker;

    function selectService(el) {
        document.querySelectorAll('.sw-service-select-card[data-service-id]').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('serviceId').value = el.dataset.serviceId;
        selectedName = el.dataset.name;
        document.getElementById('summaryService').textContent = selectedName;
        document.getElementById('serviceError').classList.add('d-none');
    }

    function selectDetergent(el) {
        document.querySelectorAll('.sw-service-select-card[data-detergent-id]').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('detergentId').value = el.dataset.detergentId;
        selectedDetergentName = el.dataset.detergentName;
        document.getElementById('summaryDetergent').textContent = selectedDetergentName;
        document.getElementById('detergentError').classList.add('d-none');
    }

    function selectConditioner(el) {
        document.querySelectorAll('.sw-service-select-card[data-conditioner-id]').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('conditionerId').value = el.dataset.conditionerId;
        selectedConditionerName = el.dataset.conditionerName;
        document.getElementById('summaryConditioner').textContent = selectedConditionerName;
        document.getElementById('conditionerError').classList.add('d-none');
    }

    function goToStep(step) {
        if (step === 2) {
            if (!document.getElementById('serviceId').value) {
                document.getElementById('serviceError').classList.remove('d-none');
                return;
            }
            if (!document.getElementById('detergentId').value) {
                document.getElementById('detergentError').classList.remove('d-none');
                return;
            }
            if (!document.getElementById('conditionerId').value) {
                document.getElementById('conditionerError').classList.remove('d-none');
                return;
            }
        }

        if (step === 3) {
            var pickup = document.getElementById('pickupAddress');
            var delivery = document.getElementById('deliveryAddress');
            var valid = true;
            if (!pickup.value.trim()) { pickup.classList.add('is-invalid'); valid = false; }
            else { pickup.classList.remove('is-invalid'); }
            
            if (!document.getElementById('sameAsPickup').checked && !delivery.value.trim()) {
                delivery.classList.add('is-invalid'); valid = false;
            } else {
                delivery.classList.remove('is-invalid');
            }
            if (!valid) return;
        }

        document.querySelectorAll('.sw-step-content').forEach(s => s.classList.add('d-none'));
        document.getElementById('step' + step).classList.remove('d-none');
        document.querySelectorAll('.sw-wizard-step').forEach((s, i) => {
            s.classList.remove('active', 'completed');
            if ((i + 1) < step) s.classList.add('completed');
            if ((i + 1) === step) s.classList.add('active');
        });
        if (step === 2 && !map) initMap();
    }

    function initMap() {
        map = L.map('orderMap').setView([14.5995, 120.9842], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
        var pickupIcon = L.divIcon({ html: '<i class="bi bi-geo-alt-fill text-danger fs-3"></i>', className: 'sw-map-icon', iconSize: [30, 30], iconAnchor: [15, 30] });
        var deliveryIcon = L.divIcon({ html: '<i class="bi bi-house-fill text-success fs-3"></i>', className: 'sw-map-icon', iconSize: [30, 30], iconAnchor: [15, 30] });
        pickupMarker = L.marker([14.5995, 120.9742], { draggable: true, icon: pickupIcon }).addTo(map).bindPopup('📍 Pickup Location');
        deliveryMarker = L.marker([14.5995, 120.9942], { draggable: true, icon: deliveryIcon }).addTo(map).bindPopup('🏠 Delivery Location');
        
        pickupMarker.on('dragend', function () { 
            reverseGeocode(pickupMarker, 'pickup'); 
            if (document.getElementById('sameAsPickup').checked) {
                deliveryMarker.setLatLng(pickupMarker.getLatLng());
                reverseGeocode(deliveryMarker, 'delivery');
            }
        });
        deliveryMarker.on('dragend', function () { reverseGeocode(deliveryMarker, 'delivery'); });
        
        reverseGeocode(pickupMarker, 'pickup');
        reverseGeocode(deliveryMarker, 'delivery');
        setTimeout(function () { map.invalidateSize(); }, 300);
    }

    function reverseGeocode(marker, type) {
        var lat = marker.getLatLng().lat;
        var lng = marker.getLatLng().lng;
        document.getElementById(type + 'Lat').value = lat;
        document.getElementById(type + 'Lng').value = lng;
        fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng)
            .then(r => r.json())
            .then(data => {
                var addr = data.display_name || '';
                var field = document.getElementById(type + 'Address');
                field.value = addr;
                field.dispatchEvent(new Event('input')); // Trigger autoresize
                document.getElementById('summary' + (type === 'pickup' ? 'Pickup' : 'Delivery')).textContent = (type === 'pickup' ? 'Pickup: ' : 'Delivery: ') + addr.substring(0, 50) + '...';
            });
    }

    function useMyLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (pos) {
                var lat = pos.coords.latitude;
                var lng = pos.coords.longitude;
                map.setView([lat, lng], 15);
                pickupMarker.setLatLng([lat, lng]);
                if (document.getElementById('sameAsPickup').checked) {
                    deliveryMarker.setLatLng([lat, lng]);
                } else {
                    deliveryMarker.setLatLng([lat + 0.002, lng + 0.002]);
                }
                reverseGeocode(pickupMarker, 'pickup');
                reverseGeocode(deliveryMarker, 'delivery');
            });
        }
    }

    function toggleSameAddress(cb) {
        var container = document.getElementById('deliveryContainer');
        var deliveryField = document.getElementById('deliveryAddress');
        if (cb.checked) {
            container.classList.add('d-none');
            deliveryField.value = document.getElementById('pickupAddress').value;
            document.getElementById('deliveryLat').value = document.getElementById('pickupLat').value;
            document.getElementById('deliveryLng').value = document.getElementById('pickupLng').value;
            if (deliveryMarker && pickupMarker) {
                deliveryMarker.setLatLng(pickupMarker.getLatLng());
            }
            document.getElementById('summaryDelivery').textContent = document.getElementById('summaryPickup').textContent.replace('Pickup:', 'Delivery:');
        } else {
            container.classList.remove('d-none');
            deliveryField.dispatchEvent(new Event('input')); // Initial resize when shown
        }
    }

    function initAutoResize() {
        document.querySelectorAll('.sw-textarea-auto').forEach(function(el) {
            el.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            });
            // Initial resize
            setTimeout(() => {
                el.style.height = 'auto';
                el.style.height = (el.scrollHeight) + 'px';
            }, 100);
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        initAutoResize();
        var now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset() + 60);
        document.getElementById('pickupDate').min = now.toISOString().slice(0, 16);
    });
</script>
</script>
}

