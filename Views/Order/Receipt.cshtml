@{
    ViewData["Title"] = "Order Receipt";
    var order = ViewBag.Order as SmartWash.Models.Order;
    var service = ViewBag.Service as SmartWash.Models.Service;
    var customer = ViewBag.Customer as SmartWash.Models.Profile;
    var detergent = ViewBag.Detergent as SmartWash.Models.Detergent;
    var warehouse = ViewBag.Warehouse as SmartWash.Models.Warehouse;

    var weighedStatuses = new[] { "Weighed & Measured", "Washing", "Ready for Delivery", "Out for Delivery", "Delivered" };
    var isWeighed = order != null && weighedStatuses.Contains(order.Status);
}

<div class="sw-page-header">
    <div class="container">
        <h2 class="fw-bold text-white mb-1"><i class="bi bi-receipt me-2"></i>Order Receipt</h2>
        <p class="text-white-50 mb-0">Order #@order?.Id</p>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="sw-card animate-stagger delay-1">
                <div class="p-5">
                    <div class="text-center mb-4">
                        <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--sw-primary),#60a5fa);">
                            <i class="bi bi-receipt text-white fs-2"></i>
                        </div>
                        <h4 class="fw-bold">SmartWash Receipt</h4>
                        <p class="text-muted small">Order #@order?.Id</p>
                        <span class="sw-status-badge sw-status-@order?.Status?.Replace(" ", "-").ToLower()">@order?.Status</span>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h6 class="fw-bold small text-muted text-uppercase mb-3">Customer</h6>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Name</span>
                            <span class="fw-semibold">@customer?.FullName</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Email</span>
                            <span class="fw-semibold">@customer?.Email</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Phone</span>
                            <span class="fw-semibold">+63 @customer?.Phone</span>
                        </div>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h6 class="fw-bold small text-muted text-uppercase mb-3">Order Details</h6>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Service</span>
                            <span class="fw-semibold">@service?.Name</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Detergent</span>
                            <span class="fw-semibold">@(detergent?.Name ?? "—")</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Weight</span>
                            <span class="fw-semibold">@(isWeighed && order.WeightKg.HasValue ? order.WeightKg.Value.ToString("F1") + " kg" : "Pending measurement")</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Price/kg</span>
                            <span class="fw-semibold">₱@service?.PricePerKg/kg</span>
                        </div>
                        @if (!string.IsNullOrEmpty(order.SpecialInstructions))
                        {
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Instructions</span>
                                <span class="fw-semibold text-end" style="max-width:60%;">@order.SpecialInstructions</span>
                                <span class="fw-semibold text-end" style="max-width:60%;">@order?.SpecialInstructions</span>
                            </div>
                        }
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h6 class="fw-bold small text-muted text-uppercase mb-3">Addresses</h6>
                        <div class="small mb-2">
                            <i class="bi bi-geo-alt text-danger me-1"></i><strong>Pickup:</strong> @order?.PickupAddress
                        </div>
                        <div class="small">
                            <i class="bi bi-house text-success me-1"></i><strong>Delivery:</strong> @order?.DeliveryAddress
                        </div>
                    </div>

                    <hr />

                    <div class="mb-4">
                        <h6 class="fw-bold small text-muted text-uppercase mb-3">Schedule</h6>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Pickup Date</span>
                            <span class="fw-semibold">@(order?.PickupDate.HasValue == true ? order.PickupDate.Value.ToString("MMM dd, yyyy") : "—")</span>
                        </div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Order Date</span>
                            <span class="fw-semibold">@(order?.CreatedAt.HasValue == true ? order.CreatedAt.Value.ToString("MMM dd, yyyy") : "—")</span>
                        </div>
                    </div>

                    @if (warehouse != null)
                    {
                        <hr />
                        <div class="mb-4">
                            <h6 class="fw-bold small text-muted text-uppercase mb-3">Warehouse</h6>
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Name</span>
                                <span class="fw-semibold">@warehouse.Name</span>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Address</span>
                                <span class="fw-semibold text-end" style="max-width:60%;">@warehouse.Address</span>
                            </div>
                        </div>
                    }

                    <div class="p-4 text-center" style="background:linear-gradient(135deg,#f8faff,#eef2ff);border-radius:var(--sw-radius);">
                        <span class="small text-muted d-block mb-1">Total Amount</span>
                        <span class="display-5 fw-bold text-primary">@(isWeighed && order?.TotalPrice.HasValue == true ? "₱" + order.TotalPrice.Value.ToString("F2") : "Pending measurement")</span>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <a href="/Order/Track/@order?.Id" class="sw-btn sw-btn-outline flex-fill" style="color:var(--sw-primary);border-color:var(--sw-primary);">
                            <i class="bi bi-geo-alt me-1"></i>Track Order
                        </a>
                        <button onclick="window.print()" class="sw-btn sw-btn-primary flex-fill">
                            <i class="bi bi-printer me-1"></i>Print
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
