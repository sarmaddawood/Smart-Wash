@{
    Layout = null;
    var order = ViewBag.Order as SmartWash.Models.Order;
    var service = ViewBag.Service as SmartWash.Models.Service;
    var customer = ViewBag.Customer as SmartWash.Models.Profile;
    var warehouse = ViewBag.Warehouse as SmartWash.Models.Warehouse;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receipt — Order #@order.Id — SmartWash</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #F8FAFF; }
        .receipt { max-width: 600px; margin: 24px auto; background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); overflow: hidden; position: relative; }
        .receipt-header { background: linear-gradient(135deg, #0A1628, #132f56); color: #fff; padding: 36px 32px; }
        .receipt-body { padding: 32px; }
        .receipt-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f1f5f9; }
        .receipt-row:last-child { border-bottom: none; }
        .receipt-label { color: #64748b; font-size: 0.88rem; }
        .receipt-value { font-weight: 600; color: #1e293b; font-size: 0.88rem; text-align: right; max-width: 55%; }
        .receipt-total { font-size: 1.5rem; color: #2563EB; font-weight: 800; }
        .receipt-footer { background: #f8fafc; padding: 20px 32px; text-align: center; border-top: 1px solid #f1f5f9; }
        .receipt-watermark { position: absolute; bottom: 80px; right: 20px; font-size: 4rem; opacity: 0.03; font-weight: 800; transform: rotate(-20deg); color: #0A1628; }
        .print-fab { position: fixed; bottom: 32px; right: 32px; z-index: 100; width: 56px; height: 56px; border-radius: 50%; background: #2563EB; color: #fff; border: none; font-size: 1.3rem; box-shadow: 0 6px 20px rgba(37,99,235,0.35); cursor: pointer; transition: all 0.3s; }
        .print-fab:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(37,99,235,0.4); }
        .back-bar { padding: 16px 24px; }
        @@media print {
            body { background: #fff; }
            .print-fab, .back-bar { display: none !important; }
            .receipt { box-shadow: none; margin: 0; border-radius: 0; }
        }
    </style>
</head>
<body>
    <div class="back-bar">
        <a href="/Order/Track/@order.Id" style="color:#2563EB;font-weight:600;font-size:0.88rem;text-decoration:none;">
            <i class="bi bi-arrow-left me-1"></i>Back to Order
        </a>
        <a href="/Customer/Dashboard" style="color:#64748b;font-weight:500;font-size:0.88rem;text-decoration:none;margin-left:16px;">
            <i class="bi bi-speedometer2 me-1"></i>Dashboard
        </a>
    </div>

    <div class="receipt">
        <div class="receipt-watermark">SmartWash</div>
        <div class="receipt-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="mb-0 fw-bold">🫧 SmartWash</h3>
                    <p class="mb-0 opacity-50" style="font-size:0.8rem;">Fresh Clothes. Zero Effort.</p>
                </div>
                <div class="text-end">
                    <h5 class="mb-0 fw-bold">RECEIPT</h5>
                    <p class="mb-0 opacity-50" style="font-size:0.8rem;">Order #@order.Id</p>
                </div>
            </div>
        </div>
        <div class="receipt-body">
            <div class="receipt-row">
                <span class="receipt-label">Date Placed</span>
                <span class="receipt-value">@order.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Customer</span>
                <span class="receipt-value">@customer.FullName</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Phone</span>
                <span class="receipt-value">+63 @customer.Phone</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Email</span>
                <span class="receipt-value">@customer.Email</span>
            </div>
            <hr style="border-color:#e2e8f0;" />
            <div class="receipt-row">
                <span class="receipt-label">Service</span>
                <span class="receipt-value">@service.Icon @service.Name</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Weight</span>
                <span class="receipt-value">@order.WeightKg kg</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Rate</span>
                <span class="receipt-value">₱@service.PricePerKg / kg</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label" style="font-weight:700;color:#1e293b;">Total</span>
                <span class="receipt-total">₱@order.TotalPrice.ToString("F2")</span>
            </div>
            <hr style="border-color:#e2e8f0;" />
            <div class="receipt-row">
                <span class="receipt-label">Pickup</span>
                <span class="receipt-value">@order.PickupAddress</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Delivery</span>
                <span class="receipt-value">@order.DeliveryAddress</span>
            </div>
            @if (warehouse != null)
            {
                <div class="receipt-row">
                    <span class="receipt-label">Warehouse</span>
                    <span class="receipt-value">@warehouse.Name</span>
                </div>
            }
            <hr style="border-color:#e2e8f0;" />
            <div class="receipt-row">
                <span class="receipt-label">Status</span>
                <span style="background:#2563EB;color:#fff;padding:4px 14px;border-radius:50px;font-size:0.78rem;font-weight:600;">@order.Status</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Pickup Date</span>
                <span class="receipt-value">@order.PickupDate</span>
            </div>
            <div class="receipt-row">
                <span class="receipt-label">Est. Delivery</span>
                <span class="receipt-value" style="color:#10B981;font-weight:700;">@order.EstimatedDelivery</span>
            </div>
        </div>
        <div class="receipt-footer">
            <p class="mb-1" style="font-size:0.78rem;color:#64748b;">📞 +63 991 671 4363 | 📧 saldivarcharme@gmail.com</p>
            <p class="mb-0" style="font-size:0.72rem;color:#94a3b8;">© 2026 SmartWash Philippines. All rights reserved.</p>
        </div>
    </div>

    <button class="print-fab" onclick="window.print()"><i class="bi bi-printer-fill"></i></button>
</body>
</html>
