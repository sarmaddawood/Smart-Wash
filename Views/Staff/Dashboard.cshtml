@{
    Layout = "_Layout";
    ViewData["Title"] = "Staff Dashboard";
    var availableOrders = ViewBag.AvailableOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var activeOrders = ViewBag.MyActiveOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var serviceDict = ViewBag.ServiceDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    var detergentDict = ViewBag.DetergentDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    var profileDict = ViewBag.ProfileDict as Dictionary<string, SmartWash.Models.Profile> ?? new Dictionary<string, SmartWash.Models.Profile>();
}

<div class="sw-page-header">
    <div class="container d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">Staff Dashboard 👔</h2>
            <p class="text-muted mb-0">Welcome back, @ViewBag.UserName</p>
        </div>
    </div>
</div>

<div class="d-flex bg-white" style="min-height: 80vh;">
    <!-- Sidebar -->
    <div class="sw-admin-sidebar d-none d-lg-block border-end py-4" style="width: 260px; min-width: 260px; background: var(--sw-white);">
        <div class="px-4 mb-3"><span class="small fw-bold text-muted text-uppercase" style="letter-spacing:1px;">Orders</span></div>
        <a class="sw-sidebar-link active" onclick="showSection('available',this)"><i class="bi bi-inbox"></i>Available Orders</a>
        <a class="sw-sidebar-link" onclick="showSection('active',this)"><i class="bi bi-person-workspace"></i>My Active Orders</a>
    </div>

    <!-- Main Content Area -->
    <div class="flex-fill p-4" style="background: var(--sw-bg);">
        <!-- Mobile Sidebar Toggle -->
        <div class="d-lg-none mb-3">
            <button class="btn btn-outline-primary w-100 bg-white" style="border-radius:var(--sw-radius-sm);" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSidebar">
                <i class="bi bi-list me-2"></i>Navigation
            </button>
            <div class="collapse mt-2" id="mobileSidebar">
                <div class="sw-card p-3">
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-sm btn-primary" style="border-radius:50px;" onclick="showSection('available',this)"><i class="bi bi-inbox me-1"></i>Available Orders</button>
                        <button class="btn btn-sm btn-outline-primary" style="border-radius:50px;" onclick="showSection('active',this)"><i class="bi bi-person-workspace me-1"></i>My Active Orders</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section: Available Orders -->
        <div id="section-available" class="admin-section">
            <h4 class="mb-3 fw-bold">Available Orders</h4>
            <div class="sw-card animate-stagger delay-1 p-3">
                <div class="table-responsive">
                    <table class="sw-table table-hover text-nowrap mb-0">
                        <thead>
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Detergent</th>
                                <th class="fs-12 text-muted text-uppercase">Pickup Address</th>
                                <th class="fs-12 text-muted text-uppercase">Date</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in availableOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>@(detergentDict.ContainsKey(order.DetergentId ?? "") ? detergentDict[order.DetergentId!] : "None")</td>
                                    <td class="text-truncate" style="max-width: 150px;">@order.PickupAddress</td>
                                    <td>@order.PickupDate?.ToString("MMM dd")</td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Staff", new { id = order.Id })" class="sw-btn sw-btn-primary p-1 px-3" style="font-size: 0.85rem; min-height: 32px;">View & Accept</a>
                                    </td>
                                </tr>
                            }
                            @if (!availableOrders.Any())
                            {
                                <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-2 mb-2 d-block"></i>No orders waiting for staff.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Section: My Active Orders -->
        <div id="section-active" class="admin-section d-none">
            <h4 class="mb-3 fw-bold">My Active Orders</h4>
            <div class="sw-card animate-stagger delay-2 p-3">
                <div class="table-responsive">
                    <table class="sw-table table-hover text-nowrap mb-0">
                        <thead>
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Weight</th>
                                <th class="fs-12 text-muted text-uppercase">Total</th>
                                <th class="fs-12 text-muted text-uppercase">Status</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in activeOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>@(order.WeightKg.HasValue ? $"{order.WeightKg}kg" : "—")</td>
                                    <td class="fw-bold">@(order.TotalPrice.HasValue ? $"₱{order.TotalPrice:F2}" : "—")</td>
                                    <td>
                                        <span class="sw-status-badge sw-status-@order.Status.Replace(" ", "-").ToLower()">@order.Status</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Staff", new { id = order.Id })" class="sw-btn sw-btn-outline p-1 px-3" style="font-size: 0.85rem; min-height: 32px;">Manage</a>
                                    </td>
                                </tr>
                            }
                            @if (!activeOrders.Any())
                            {
                                <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-person-workspace fs-2 mb-2 d-block"></i>You have no active orders.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showSection(name, el) {
        document.querySelectorAll('.admin-section').forEach(s => s.classList.add('d-none'));
        document.getElementById('section-' + name).classList.remove('d-none');
        document.querySelectorAll('.sw-sidebar-link').forEach(l => l.classList.remove('active'));
        if (el && el.classList.contains('sw-sidebar-link')) el.classList.add('active');

        // Update mobile buttons
        document.querySelectorAll('#mobileSidebar .btn').forEach(btn => {
            btn.classList.remove('btn-primary');
            btn.classList.add('btn-outline-primary');
        });
        if (el && Array.from(el.parentNode.children).includes(el) === false) {
             el.classList.remove('btn-outline-primary');
             el.classList.add('btn-primary');
        }
    }
</script>
}
