@{
    Layout = "_Layout";
    ViewData["Title"] = "Staff Dashboard";
    var availableOrders = ViewBag.AvailableOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var activeOrders = ViewBag.MyActiveOrders as List<SmartWash.Models.Order> ?? new List<SmartWash.Models.Order>();
    var serviceDict = ViewBag.ServiceDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    var detergentDict = ViewBag.DetergentDict as Dictionary<string, string> ?? new Dictionary<string, string>();
    var profileDict = ViewBag.ProfileDict as Dictionary<string, SmartWash.Models.Profile> ?? new Dictionary<string, SmartWash.Models.Profile>();
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Staff Dashboard</h1>
        <div class="text-muted fs-12">Welcome, @ViewBag.UserName</div>
    </div>

    <div class="card animate-stagger delay-1 p-3 mb-4">
        <ul class="nav nav-tabs mb-3" id="staffTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fs-12 fw-bold text-uppercase" id="available-tab" data-bs-toggle="tab" data-bs-target="#available" type="button" role="tab">Available Orders</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fs-12 fw-bold text-uppercase" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab">My Active Orders</button>
            </li>
        </ul>
        <div class="tab-content" id="staffTabsContent">
            <div class="tab-pane fade show active" id="available" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-sm table-hover text-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Detergent</th>
                                <th class="fs-12 text-muted text-uppercase">Pickup Address</th>
                                <th class="fs-12 text-muted text-uppercase">Date</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in availableOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>@(detergentDict.ContainsKey(order.DetergentId ?? "") ? detergentDict[order.DetergentId!] : "None")</td>
                                    <td class="text-truncate" style="max-width: 150px;">@order.PickupAddress</td>
                                    <td>@order.PickupDate?.ToString("MMM dd")</td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Staff", new { id = order.Id })" class="btn btn-primary btn-sm">View & Accept</a>
                                    </td>
                                </tr>
                            }
                            @if (!availableOrders.Any())
                            {
                                <tr><td colspan="7" class="text-center py-3 text-muted">No orders waiting for staff.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane fade" id="active" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-sm table-hover text-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="fs-12 text-muted text-uppercase">Order ID</th>
                                <th class="fs-12 text-muted text-uppercase">Customer</th>
                                <th class="fs-12 text-muted text-uppercase">Service</th>
                                <th class="fs-12 text-muted text-uppercase">Weight</th>
                                <th class="fs-12 text-muted text-uppercase">Total</th>
                                <th class="fs-12 text-muted text-uppercase">Status</th>
                                <th class="fs-12 text-muted text-uppercase">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in activeOrders)
                            {
                                var customer = profileDict.ContainsKey(order.CustomerId ?? "") ? profileDict[order.CustomerId!] : null;
                                <tr>
                                    <td class="text-truncate" style="max-width: 80px;">@order.Id</td>
                                    <td>@(customer?.FullName ?? "Unknown")</td>
                                    <td>@(serviceDict.ContainsKey(order.ServiceId ?? "") ? serviceDict[order.ServiceId!] : "Unknown")</td>
                                    <td>@(order.WeightKg.HasValue ? $"{order.WeightKg}kg" : "—")</td>
                                    <td class="fw-bold">@(order.TotalPrice.HasValue ? $"₱{order.TotalPrice:F2}" : "—")</td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill fs-12">@order.Status</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("OrderDetail", "Staff", new { id = order.Id })" class="btn btn-outline-primary btn-sm">Manage</a>
                                    </td>
                                </tr>
                            }
                            @if (!activeOrders.Any())
                            {
                                <tr><td colspan="7" class="text-center py-3 text-muted">You have no active orders.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
